# GitHub Pages build output
_site/

# Dependencies
node_modules/
**/node_modules/

# Build / dist
dist/
**/dist/
lan/dist/
lan/dist_backup_*/
lan/release/

# Secrets & local env
.env
.env.local
**/.env
!**/.env.example

# Database & uploads (local data)
backend/data/*.db
backend/data/*.db-*
backend/data/*.db-journal
backend/data/*.db-wal
backend/data/*.db-shm
uploads/avatars/*
!uploads/avatars/.gitkeep

# Logs & OS
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.sw?

# Electron / launcher heavy artifacts
lan/node_modules/
lan/obfuscator/*.jar
lan/obfuscator/tools/*.jar
!lan/obfuscator/tools/.gitkeep

# Accidental copies in obfuscator folder
lan/obfuscator/node
lan/obfuscator/npm
lan/obfuscator/client-launcher@*
